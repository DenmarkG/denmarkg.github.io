# Always save exact versions — prevents ^ or ~ ranges from creeping in via `npm install <pkg>`
save-exact=true

# Enforce lock file existence; fail if package-lock.json is missing
package-lock=true

# Do not execute pre/post install lifecycle scripts from dependencies.
# Mitigates supply-chain attacks that run malicious code during `npm install`.
# Safe here because @types/jquery and typescript have no required install scripts.
ignore-scripts=true
